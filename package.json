{
  "name": "ico-generator",
  "displayName": "ICO Generator",
  "description": "Generate ICO files from images",
  "version": "1.0.0",
  "publisher": "mattiaz9",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mattiaz9/ico-generator"
  },
  "bugs": {
    "url": "https://github.com/mattiaz9/ico-generator/issues"
  },
  "homepage": "https://github.com/mattiaz9/ico-generator#readme",
  "keywords": [
    "ico",
    "icon",
    "image",
    "converter",
    "favicon",
    "png",
    "svg"
  ],
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "ICO Generator",
      "properties": {
        "ico-generator.outputSize": {
          "type": "number",
          "default": 64,
          "minimum": 16,
          "maximum": 256,
          "description": "Output size in pixels for the generated ICO file (width and height)."
        },
        "ico-generator.backgroundColor": {
          "type": "string",
          "default": "transparent",
          "description": "Background color for the ICO. Use 'transparent' for transparency, or a hex color (e.g. '#ffffff') to flatten transparent areas."
        }
      }
    },
    "commands": [
      {
        "command": "ico-generator.generateIco",
        "title": "Generate .ico"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "ico-generator.generateIco",
          "when": "resourceFilename =~ /\\.(png|jpg|jpeg|svg)$/i"
        }
      ],
      "explorer/context": [
        {
          "command": "ico-generator.generateIco",
          "when": "resourceFilename =~ /\\.(png|jpg|jpeg|svg)$/i",
          "group": "7_modification"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "build:icon": "node scripts/build-icon.mjs",
    "package": "pnpm run compile && pnpm exec vsce package"
  },
  "dependencies": {
    "png-to-ico": "^3.0.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.0",
    "eslint": "^9.17.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.18.0"
  },
  "packageManager": "pnpm@10.31.0"
}
